# Claude Code / Serena working dirs
.claude/
.serena/

# Go build artifacts
/build/
/bin/
/dist/
*.test
*.out
coverage.*

# MkDocs build output (the static site is generated, not committed)
/site/
.cache/

# Workspace pin (new format) — contains plaintext claude-mem API key after
# bootstrap. The glob also covers sidecar files: .vb.env (bootstrapped API
# key), .vb.lock (per-workspace setup lock), etc.
.vb
.vb.*

# OS / editor noise
.DS_Store
core
*.swp
.idea/
.vscode/

# Manual build-matrix testing scratch dir (configs/results/logs stay local;
# the codex-materialize and opencode-materialize gates are real deliverables
# and are tracked below).
test-scenarios/*
!test-scenarios/codex-materialize-test.sh
!test-scenarios/opencode-materialize-test.sh
!test-scenarios/pi-materialize-test.sh
