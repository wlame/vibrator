# ============================================================================
FROM claude-mcp AS runtime
ARG USERNAME=claude-user

USER root

# Create container-specific Claude rules directory
RUN mkdir -p /opt/container-rules

# Decode and install container rules
RUN echo '@@CONTAINER_RULES_CONTEXT_B64@@' | base64 -d > /opt/container-rules/docker-container-context.md
RUN echo '@@CONTAINER_RULES_SAFETY_B64@@' | base64 -d > /opt/container-rules/safety-restrictions.md

# Decode and install the production-readiness audit prompt.
# Available to every session at /opt/audit/production-audit-prompt.md —
# copy it into a target repo (or paste its contents into Claude Code) to run
# the full multi-phase audit. See .claude/analysis/how-to-run-audit.md in
# the vibrator source repo for the full runbook.
RUN mkdir -p /opt/audit && \
    echo '@@AUDIT_PROMPT_B64@@' | base64 -d > /opt/audit/production-audit-prompt.md

RUN chown $USERNAME:$USERNAME /tmp

RUN echo '@@ENTRYPOINT_B64@@' | base64 -d > /entrypoint.sh && chmod +x /entrypoint.sh
RUN echo '@@CLAUDE_EXEC_B64@@' | base64 -d > /usr/local/bin/claude-exec && chmod +x /usr/local/bin/claude-exec
USER $USERNAME
WORKDIR /home/$USERNAME

ENV COLORTERM=truecolor
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
ENV CLAUDE_CODE_UNDERCOVER=1
ENV DISABLE_TELEMETRY=1

# Variant metadata baked at build time. Surfaced in the welcome message
# (zshrc) and available to in-container tools that want to introspect
# what was installed. See docs/build-options.md for the full feature catalog.
ARG VIBRATOR_PROFILE=default
ARG VIBRATOR_FEATURES=""
ARG VIBRATOR_VARIANT_FINGERPRINT=unknown
# Redeclare CLAUDE_CLI_VERSION here so it can be read as ${VAR} in LABEL — ARGs
# don't cross stage boundaries.
ARG CLAUDE_CLI_VERSION=latest
ENV VIBRATOR_PROFILE=$VIBRATOR_PROFILE
ENV VIBRATOR_FEATURES_LIST=$VIBRATOR_FEATURES
ENV VIBRATOR_VARIANT_FINGERPRINT=$VIBRATOR_VARIANT_FINGERPRINT
ENV VIBRATOR_CLAUDE_VERSION=$CLAUDE_CLI_VERSION
LABEL vibrator.profile=$VIBRATOR_PROFILE
LABEL vibrator.features=$VIBRATOR_FEATURES
LABEL vibrator.variant=$VIBRATOR_VARIANT_FINGERPRINT
LABEL claude.version=$CLAUDE_CLI_VERSION

RUN echo '@@ZSHRC_B64@@' | base64 -d > ~/.zshrc

# Seed zsh history so "up arrow" gives a useful first command
@@IF_FULL@@
RUN echo ': 1731000000:0;claude "/sc:load"' > ~/.zsh_history
@@ENDIF_FULL@@
@@IF_SIMPLE@@
RUN echo ': 1731000000:0;claude' > ~/.zsh_history
@@ENDIF_SIMPLE@@

ENTRYPOINT ["/entrypoint.sh"]
CMD ["/bin/zsh"]
