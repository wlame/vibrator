# Conditional claude-mem install — manual approach (no npx wizard).
#
# We deliberately bypass `npx claude-mem install` because its non-TTY
# defaults are unreliable: prompts like "Overwrite existing installation?"
# silently default to No, and the IDE-specific hook wiring step doesn't
# fire when stdin isn't a terminal. Instead we do exactly what's needed
# to make Claude Code load the plugin and fire its hooks:
#   1. Clone the marketplace
#   2. Copy plugin into a versioned cache dir (where Claude's loader looks)
#   3. Register in installed_plugins.json + known_marketplaces.json
#   4. Merge the plugin's own hooks.json into ~/.claude/settings.json + mark enabled
#
# This produces the same on-disk state as a successful interactive install,
# but is fully deterministic and visible in the build log. Failures don't
# block the build — image still works, just without claude-mem wired.
RUN case " $VIBRATOR_FEATURES " in \
      *" claude-mem "*) \
        echo "[vibrator] Installing claude-mem (manual approach)" && \
        set -e && \
        mkdir -p "$HOME/.claude/plugins/marketplaces" && \
        git clone --depth 1 https://github.com/thedotmack/claude-mem.git \
          "$HOME/.claude/plugins/marketplaces/thedotmack" && \
        CM_GIT_SHA=$(cd "$HOME/.claude/plugins/marketplaces/thedotmack" && git rev-parse HEAD) && \
        CM_GIT_SHORT=$(echo "$CM_GIT_SHA" | cut -c1-12) && \
        CM_DEST="$HOME/.claude/plugins/cache/thedotmack/claude-mem/$CM_GIT_SHORT" && \
        mkdir -p "$CM_DEST" && \
        cp -r "$HOME/.claude/plugins/marketplaces/thedotmack/plugin/." "$CM_DEST/" && \
        TS=$(date -u +%Y-%m-%dT%H:%M:%S.000Z) && \
        [ -f "$HOME/.claude/plugins/installed_plugins.json" ] || echo '{"version":2,"plugins":{}}' > "$HOME/.claude/plugins/installed_plugins.json" && \
        jq --arg path "$CM_DEST" --arg v "$CM_GIT_SHORT" --arg ts "$TS" --arg sha "$CM_GIT_SHA" \
           '.plugins["claude-mem@thedotmack"] = [{scope:"user",installPath:$path,version:$v,installedAt:$ts,lastUpdated:$ts,gitCommitSha:$sha}]' \
           "$HOME/.claude/plugins/installed_plugins.json" > /tmp/inst.json && \
           mv /tmp/inst.json "$HOME/.claude/plugins/installed_plugins.json" && \
        [ -f "$HOME/.claude/plugins/known_marketplaces.json" ] || echo '{}' > "$HOME/.claude/plugins/known_marketplaces.json" && \
        jq --arg path "$HOME/.claude/plugins/marketplaces/thedotmack" --arg ts "$TS" \
           '.thedotmack = {source:{source:"github",repo:"thedotmack/claude-mem"},installLocation:$path,lastUpdated:$ts}' \
           "$HOME/.claude/plugins/known_marketplaces.json" > /tmp/mkt.json && \
           mv /tmp/mkt.json "$HOME/.claude/plugins/known_marketplaces.json" && \
        [ -f "$HOME/.claude/settings.json" ] || echo '{}' > "$HOME/.claude/settings.json" && \
        jq --slurpfile cm "$HOME/.claude/plugins/marketplaces/thedotmack/plugin/hooks/hooks.json" \
           '.hooks = (.hooks // {}) + ($cm[0].hooks // {}) | .enabledPlugins = (.enabledPlugins // {}) + {"claude-mem@thedotmack": true}' \
           "$HOME/.claude/settings.json" > /tmp/settings.json && \
           mv /tmp/settings.json "$HOME/.claude/settings.json" && \
        echo "[vibrator] claude-mem manual install complete:" && \
        echo "  installPath: $CM_DEST" && \
        echo "  hooks: $(jq -r '.hooks | keys | join(\", \")' $HOME/.claude/settings.json)" ;; \
      *) \
        echo "[vibrator] Skipping claude-mem install (not in features)" ;; \
    esac

