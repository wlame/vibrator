export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="example"
plugins=(git zsh-autosuggestions zsh-syntax-highlighting)
source $ZSH/oh-my-zsh.sh

# Prompt prefix
export PS1="%F{yellow}[%F{red}vb%F{yellow}]%f $PS1"

# History
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000

# Claude aliases - conditional on dangerous mode
if [ "$VIBRATOR_DANGEROUS" = "1" ]; then
  alias claude="claude --dangerously-skip-permissions"
fi
alias claude-safe="command claude"

# General aliases
alias ll="ls -la"

# Use neovim if available, otherwise fall back to vim
if command -v nvim >/dev/null 2>&1; then
  alias vim="nvim"
  alias vi="nvim"
fi

# Git SSH configuration
export GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

# Welcome message (interactive shells only)
if [[ -o interactive ]]; then
  echo -e "\033[1;36m+--------------------------------------------------------------+\033[0m"
  echo -e "\033[1;36m|\033[0m  \033[1;33mClaude Code Docker Environment\033[0m                              \033[1;36m|\033[0m"
  echo -e "\033[1;36m+--------------------------------------------------------------+\033[0m"
  echo ""
  _claude_version=$(claude --version 2>/dev/null | head -1 || echo 'Not installed')
  if [ "$CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS" = "1" ]; then
    _teams_badge=" \033[38;5;208mAgent teams enabled\033[0m \033]8;;https://code.claude.com/docs/en/agent-teams\007↗ docs\033]8;;\007"
  else
    _teams_badge=""
  fi
  echo -e "\033[1;32mClaude CLI:\033[0m $_claude_version$_teams_badge"
  unset _claude_version _teams_badge

  # Authentication status
  if [ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
    echo -e "\033[1;32mAuthentication:\033[0m Authenticated by OAuth token"
  elif [ -n "$ANTHROPIC_API_KEY" ]; then
    echo -e "\033[1;32mAuthentication:\033[0m Authenticated by Anthropic API Key"
  else
    echo -e "\033[1;33mAuthentication:\033[0m Not authenticated"
    echo ""
    echo -e "\033[1;33m  Tip:\033[0m Run \033[1mclaude auth login\033[0m to authenticate interactively,"
    echo -e "       or set \033[1mANTHROPIC_API_KEY\033[0m on the host and restart with:"
    echo -e "       \033[1;90mANTHROPIC_API_KEY=sk-... vibrate\033[0m"
  fi

  echo ""
  # Variant + features (baked at build time via VIBRATOR_PROFILE /
  # VIBRATOR_FEATURES_LIST). Falls back to a hint for images built before
  # the feature-flag system landed.
  if [ -n "$VIBRATOR_PROFILE" ]; then
    _profile_line="$VIBRATOR_PROFILE"
    [ -n "$VIBRATOR_VARIANT_FINGERPRINT" ] && _profile_line="$_profile_line \033[1;90m($VIBRATOR_VARIANT_FINGERPRINT)\033[0m"
    echo -e "\033[1;32mProfile:\033[0m $_profile_line"
    if [ -n "$VIBRATOR_FEATURES_LIST" ]; then
      # paste -sd ', ' cycles through TWO delimiters (',' then ' '), producing
      # "a,b c,d" instead of "a, b, c, d". Use awk for a clean join.
      _features_csv=$(echo "$VIBRATOR_FEATURES_LIST" | awk '{
        for(i=1;i<=NF;i++) printf "%s%s", $i, (i<NF?", ":"")
      }')
      echo -e "\033[1;32mFeatures:\033[0m $_features_csv"
    fi
    unset _profile_line _features_csv
  else
    echo -e "\033[1;90mFeatures:\033[0m (image predates feature-flag system — rebuild to populate)"
  fi

  # claude-mem status: only emit a line when the feature is part of this
  # image. Three states based on what the entrypoint resolved at startup:
  #   - configured + reachable   → green
  #   - configured + unreachable → yellow (host stack down)
  #   - enabled but unconfigured → yellow with setup hint
  case " ${VIBRATOR_FEATURES_LIST:-} " in
    *" claude-mem "*)
      if [ -n "$CLAUDE_MEM_RUNTIME" ] && [ -n "$CLAUDE_MEM_SERVER_BETA_URL" ]; then
        if curl -sf --connect-timeout 0.3 --max-time 0.5 "$CLAUDE_MEM_SERVER_BETA_URL/healthz" >/dev/null 2>&1; then
          echo -e "\033[1;32mclaude-mem:\033[0m connected to $CLAUDE_MEM_SERVER_BETA_URL"
        else
          echo -e "\033[1;33mclaude-mem:\033[0m configured but unreachable at $CLAUDE_MEM_SERVER_BETA_URL"
          echo -e "  \033[1;90mIs the docker-compose stack up on the host?\033[0m"
        fi
      else
        echo -e "\033[1;33mclaude-mem:\033[0m enabled but not configured on host"
        echo -e "  \033[1;90mRun \033[1mvibrate --claude-mem-setup\033[0;1;90m on host for instructions.\033[0m"
      fi
      ;;
  esac
  if [ "$CLAUDE_CODE_UNDERCOVER" = "1" ]; then
    echo -e "\033[1;32mUndercover mode:\033[0m ON"
  fi

  # Codex CLI status — used by the /planning:exec skill for external review.
  # Auth comes from host ~/.codex (mounted) or $OPENAI_API_KEY (forwarded).
  if command -v codex >/dev/null 2>&1; then
    _codex_version=$(codex --version 2>/dev/null | head -1 || echo 'unknown')
    if [ -f "$HOME/.codex/auth.json" ]; then
      _codex_auth="host ~/.codex"
    elif [ -n "$OPENAI_API_KEY" ]; then
      _codex_auth="\$OPENAI_API_KEY"
    else
      _codex_auth="\033[1;33mnot authenticated\033[0m (run \033[1mcodex login\033[0m)"
    fi
    echo -e "\033[1;32mCodex CLI:\033[0m $_codex_version ($_codex_auth)"
    unset _codex_version _codex_auth
  fi

  # Audit toolkit status — shows which production-readiness audit tools
  # are available. Drives the prompt at /opt/audit/production-audit-prompt.md
  # (see also .claude/analysis/how-to-run-audit.md in any vibrator-enabled repo).
  _audit_present=""
  for _tool in trivy syft grype semgrep gitleaks trufflehog osv-scanner scc lizard bandit checkov dockle shellcheck hadolint; do
    command -v "$_tool" >/dev/null 2>&1 && _audit_present="${_audit_present}${_tool} "
  done
  if [ -n "$_audit_present" ]; then
    _audit_count=$(echo "$_audit_present" | wc -w)
    echo -e "\033[1;32mAudit toolkit:\033[0m ${_audit_count} tools ready \033[1;90m(trivy, syft, grype, semgrep, gitleaks, ...)\033[0m"
    if [ -f /opt/audit/production-audit-prompt.md ]; then
      echo -e "  \033[1;90mStart audit:\033[0m \033[1mcat /opt/audit/production-audit-prompt.md\033[0m \033[1;90m(paste into Claude Code)\033[0m"
    fi
  fi
  unset _audit_present _audit_count _tool

  echo ""
  echo -e "\033[1;32mWorkspace:\033[0m $WORKSPACE_PATH"
  echo ""

  # Docker-in-Docker security warning
  if [ "$VIBRATOR_DOCKER_IN_DOCKER" = "1" ]; then
    echo -e "\033[1;33m+--------------------------------------------------------------+\033[0m"
    echo -e "\033[1;33m|  ⚠️  DOCKER-IN-DOCKER MODE ENABLED\033[0m                          \033[1;33m|\033[0m"
    echo -e "\033[1;33m+--------------------------------------------------------------+\033[0m"
    echo -e "\033[1;33m   This container runs with ELEVATED PRIVILEGES:\033[0m"
    echo -e "   • Docker socket mounted (/var/run/docker.sock)"
    echo -e "   • CAP_SYS_ADMIN capability granted"
    echo -e "   • Seccomp filtering disabled"
    echo ""
    echo -e "\033[1;33m   Security Impact:\033[0m"
    echo -e "   • Container escape is possible if compromised"
    echo -e "   • Full access to host Docker daemon"
    echo -e "   • Use only when Docker commands are needed"
    echo ""
    echo -e "\033[1;90m   Run without --dind/--docker for secure mode\033[0m"
    echo -e "\033[1;33m+--------------------------------------------------------------+\033[0m"
    echo ""
  fi

  echo -e "\033[1;90mType 'claude --help' to get started\033[0m"
  echo ""
fi
