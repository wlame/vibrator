RUN ARCH=$(dpkg --print-architecture) && \
    DOCKLE_VERSION="0.4.15" && \
    if [ "$ARCH" = "amd64" ]; then DK_ARCH="64bit"; else DK_ARCH="ARM64"; fi && \
    curl -fsSL --retry 3 --retry-delay 5 --retry-all-errors \
