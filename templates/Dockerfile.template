# - gosec: Go-specific security analyzer (complements golangci-lint)
# - staticcheck: Go static analyzer (complements golangci-lint)
RUN GOBIN=/usr/local/bin go install github.com/google/osv-scanner/v2/cmd/osv-scanner@latest && \
    GOBIN=/usr/local/bin go install github.com/boyter/scc/v3@latest && \
    GOBIN=/usr/local/bin go install github.com/securego/gosec/v2/cmd/gosec@latest && \
    GOBIN=/usr/local/bin go install honnef.co/go/tools/cmd/staticcheck@latest

